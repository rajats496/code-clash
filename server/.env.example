# server/.env.example
PORT=5000
MONGO_URI=mongodb://localhost:27017/codeclash
JWT_SECRET=your_super_secret_jwt_key_change_in_production
GOOGLE_CLIENT_ID=your_google_client_id_here
CLIENT_URL=http://localhost:3003
NODE_ENV=development

# ── Judge0 Code Execution ───────────────────────────────────────────────
# Option A: RapidAPI hosted (free tier — 50 req/day)
#   Sign up: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Option B: Self-hosted via Docker (unlimited, recommended for dev)
#   docker run -d -p 2358:2358 judge0/judge0
# JUDGE0_API_URL=http://localhost:2358
# JUDGE0_API_KEY=
# JUDGE0_API_HOST=

JUDGE0_TIMEOUT=30000

# ── Self-Hosted Judge0 for Contests (RECOMMENDED) ───────────────────────
# Run: docker-compose -f docker-compose.judge0.yml up -d
# This gives you UNLIMITED sandboxed code execution
JUDGE0_SELF_HOSTED_URL=http://localhost:2358

# ── Redis (for BullMQ submission queue + leaderboard) ────────────────────
# The app-redis service in docker-compose runs on port 6380
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=           # Set if you enable Redis AUTH

# ── JDoodle (legacy 1v1 matches — 200 free/day) ─────────────────────────
# JDOODLE_CLIENT_ID=your_id
# JDOODLE_CLIENT_SECRET=your_secret